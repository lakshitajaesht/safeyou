{
  "name": "safeyou",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Firefox phishing protection extension and Vercel-compatible reputation API",
  "scripts": {
    "dev": "node --watch server/local-server.js",
    "start": "node server/local-server.js",
    "test": "node --test",
    "build:chrome": "mkdir -p dist && cd extension-chrome && zip -r -FS ../dist/safeyou-chrome.zip . -x '*.DS_Store'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@litko/yara-x": "^0.6.1",
    "dotenv": "^16.6.1",
    "mongodb": "^6.17.0",
    "tldts": "^7.0.8"
  }
}
